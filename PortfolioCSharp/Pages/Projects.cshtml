@page
@{
    ViewData["Title"] = "Projects";
}

<section class="page-title">
    <div class="eyebrow">Case Studies</div>
    <h1>Featured Projects</h1>
    <p>Projects focused on solving real workflow problems, not just showing UI.</p>
</section>

<section class="section">
    <div class="project-list">
        <article class="project-card">
            <div class="project-tag">ASP.NET / SQL Server</div>
            <h2>PCN Online System</h2>
            <p>
                A production request system for creating PCN jobs, attaching files,
                managing detail rows, and tracking approval status across departments.
            </p>
            <ul>
                <li>Multi-step approval</li>
                <li>Dynamic detail table</li>
                <li>File attachment</li>
                <li>Email notification</li>
            </ul>
        </article>

        <article class="project-card">
            <div class="project-tag">Dashboard / Chart</div>
            <h2>Department KPI Dashboard</h2>
            <p>
                Dashboard for managers to monitor weekly jobs, pending status,
                average processing time, and employee-level performance.
            </p>
            <ul>
                <li>Department summary</li>
                <li>Employee detail</li>
                <li>Average process time</li>
                <li>Status cards</li>
            </ul>
        </article>

        <article class="project-card">
            <div class="project-tag">Automation</div>
            <h2>Excel & Database Automation</h2>
            <p>
                A C# automation tool for reading Excel files, comparing part numbers,
                updating SQL Server records, and reducing manual work.
            </p>
            <ul>
                <li>Excel processing</li>
                <li>SQL Server update</li>
                <li>Data comparison</li>
                <li>Error handling</li>
            </ul>
        </article>
    </div>
</section>
