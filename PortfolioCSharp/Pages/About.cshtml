@page
@{
    ViewData["Title"] = "About";
}

<section class="page-title">
    <div class="eyebrow">About Me</div>
    <h1>C# Developer for Business Systems</h1>
    <p>
        I build internal tools that support real users, real departments,
        and real production workflows.
    </p>
</section>

<section class="section about-grid">
    <div class="about-card">
        <h2>Focus</h2>
        <p>
            My work focuses on approval systems, dashboards, file upload,
            reporting, SQL Server, and automation for office/factory teams.
        </p>
    </div>

    <div class="about-card">
        <h2>Skill Stack</h2>
        <div class="skill-tags">
            <span>C#</span>
            <span>ASP.NET Core</span>
            <span>Razor Pages</span>
            <span>SQL Server</span>
            <span>JavaScript</span>
            <span>Bootstrap</span>
            <span>Excel Automation</span>
            <span>Email Automation</span>
        </div>
    </div>
</section>
