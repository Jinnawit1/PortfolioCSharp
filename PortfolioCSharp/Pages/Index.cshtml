@page
@{
    ViewData["Title"] = "Home";
}
Safe
<section class="hero">
    <div class="hero-content">
        <div class="eyebrow">Business System Developer Portfolio</div>
        <h1>I build internal systems that help teams work faster.</h1>
        <p>
            C# developer focused on approval workflows, KPI dashboards,
            document control, SQL Server reporting, and practical automation tools.
        </p>
        <div class="hero-actions">
            <a class="btn btn-primary" asp-page="/Projects">View Projects</a>
            <a class="btn btn-secondary" asp-page="/Contact">Contact Me</a>
        </div>
    </div>

    <div class="hero-card">
        <div class="status"></div>
        <h2>Production-ready Developer</h2>
        <p>ASP.NET Core / C# / SQL Server / JavaScript</p>
        <div class="stat-grid">
            <div>
                <strong>Workflow</strong>
                <span>Approval systems</span>
            </div>
            <div>
                <strong>Dashboard</strong>
                <span>KPI reports</span>
            </div>
            <div>
                <strong>Automation</strong>
                <span>Excel & email</span>
            </div>
            <div>
                <strong>Database</strong>
                <span>SQL Server</span>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="section-heading">
        <h2>What I Build</h2>
        <p>Practical applications for office, factory, and internal business operations.</p>
    </div>

    <div class="card-grid four">
        <div class="info-card">
            <span>01</span>
            <h3>Approval Workflow</h3>
            <p>Multi-step request approval with pending, approved, rejected, and notification flow.</p>
        </div>
        <div class="info-card">
            <span>02</span>
            <h3>KPI Dashboard</h3>
            <p>Weekly and monthly dashboards for department, employee, average time, and status tracking.</p>
        </div>
        <div class="info-card">
            <span>03</span>
            <h3>Document Control</h3>
            <p>File upload, document version, attachments, and request evidence management.</p>
        </div>
        <div class="info-card">
            <span>04</span>
            <h3>Automation Tools</h3>
            <p>Excel import, SQL update, email automation, QR scan, and data cleanup tools.</p>
        </div>
    </div>
</section>

<section class="section split-section">
    <div>
        <h2>My Development Style</h2>
        <p>
            I focus on understanding the real workflow first, then build simple screens
            that users can operate quickly. The goal is not only good UI, but fewer manual steps.
        </p>
    </div>
    <div class="process-list">
        <div>Understand workflow</div>
        <div>Design simple UI</div>
        <div>Develop stable features</div>
        <div>Test with real cases</div>
        <div>Deploy and improve</div>
    </div>
</section>
